# -----------------------------------------------------------------------
# Required — LegiScan
# -----------------------------------------------------------------------

# LegiScan API key. Server-side only. Never expose to the client.
# Obtain from: https://legiscan.com/legiscan
LEGISCAN_API_KEY=

# -----------------------------------------------------------------------
# Required — Upstash Redis (rate limiting)
# -----------------------------------------------------------------------

# Upstash Redis REST endpoint URL.
# Create a database at: https://console.upstash.com
UPSTASH_REDIS_REST_URL=

# Upstash Redis REST token.
UPSTASH_REDIS_REST_TOKEN=

# -----------------------------------------------------------------------
# Optional
# -----------------------------------------------------------------------

# Canonical public URL of the deployed application.
# Used for absolute URL construction (e.g. canonical links, CORS).
# Example: https://advocata.example.com
NEXT_PUBLIC_APP_URL=
